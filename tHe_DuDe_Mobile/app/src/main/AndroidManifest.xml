<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌐 Internet & Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    
    <!-- 📷 Camera & Media -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />
    
    <!-- 📞 Communication (for URL Scheme handling) -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    
    <!-- 🔔 Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 🌙 Keep screen on during analysis -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_themis"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_themis_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ThemisVerdict"
        android:usesCleartextTraffic="true"
        android:name=".ThemisApplication"
        tools:targetApi="34">
        
        <!-- ⚖️ Main Activity - Direct Access to Themis Interface -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ThemisVerdict"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- 🔗 Deep Link for Themis URLs -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" 
                      android:host="themis.thegodseller.com" />
            </intent-filter>
            
            <!-- 📧 Handle email schemes -->
            <intent-filter>
                <action android:name="android.intent.action.SENDTO" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="mailto" />
            </intent-filter>
            
        </activity>
        
        <!-- 📊 Workflow Service - Background Agent Sync -->
        <service
            android:name=".service.WorkflowSyncService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:description="@string/workflow_service_desc" />
            
        <!-- 🔔 Notification Channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="themis_workflow_channel" />
            
    </application>

</manifest>
