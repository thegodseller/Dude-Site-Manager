+def decode_7segment(digit_img) -> str:
+    """
+    Highly robust 7-segment decoder with minus sign and Otsu threshold support.
+    """
+    import cv2
+    import numpy as np
 
+    # 1. Binarize using Otsu (Adaptive to light)
+    # We use Otsu's to find the best threshold automatically
+    _, binary = cv2.threshold(digit_img, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
+    h, w = binary.shape
+    if h < 8 or w < 3: return ""
+
+    # 2. Deskew (Slant correction)
+    m = cv2.moments(binary)
+    if m['m00'] > 50: # Only deskew if enough pixels
+        mu11 = m['mu11'] / m['m00']
+        mu02 = m['mu02'] / m['m00']
+        slant = mu11 / mu02
+        M = np.float32([[1, -slant, 0.5 * h * slant], [0, 1, 0]])
+        binary = cv2.warpAffine(binary, M, (w, h), flags=cv2.INTER_LINEAR)
+
+    # 3. Stretch Horizontally
+    binary = cv2.resize(binary, (w * 2, h), interpolation=cv2.INTER_NEAREST)
+    h, w = binary.shape
+
+    # 4. Scan Lines (Tighter positioning)
+    h_lines = [0.15, 0.50, 0.85]
+    v_lines = [0.35, 0.65] # Moved closer to center
+    
+    h_hits = []
+    for hl in h_lines:
+        row = binary[int(hl*h), int(0.35*w):int(0.65*w)]
+        h_hits.append(np.mean(row) > 100)
+        
+    v_hits = [[False, False], [False, False]] 
+    for i, vl in enumerate(v_lines):
+        col = binary[:, int(vl*w)]
+        top_part = col[int(0.15*h):int(0.40*h)]
+        bot_part = col[int(0.60*h):int(0.85*h)]
+        v_hits[i][0] = np.mean(top_part) > 100
+        v_hits[i][1] = np.mean(bot_part) > 100
+        
+    lt, lb = v_hits[0]
+    rt, rb = v_hits[1]
+    t, m, b = h_hits
+    
+    # 5. Mapping with Minus Sign support
+    res = ""
+    # Standard 0-9
+    if t and b and lt and lb and rt and rb and not m: res = "0"
+    elif rt and rb and not t and not m and not b: res = "1"
+    elif t and m and b and rt and lb and not lt and not rb: res = "2"
+    elif t and m and b and rt and rb and not lt and not lb: res = "3"
+    elif m and lt and rt and rb and not t and not b: res = "4"
+    elif t and m and b and lt and rb and not rt and not lb: res = "5"
+    elif t and m and b and lt and lb and rb and not rt: res = "6"
+    elif t and rt and rb and not m and not b: res = "7"
+    elif t and m and b and lt and lb and rt and rb: res = "8"
+    elif t and m and b and lt and rt and rb and not lb: res = "9"
+    
+    # Special: Minus Sign
+    if not res and m and not t and not b and not lt and not lb and not rt and not rb:
+        res = "-"
+        
+    # Special: '1' fallback
+    if not res and rt and rb: res = "1"
+    
+    return res
+
+def run_ocr_single_region(image_path: Path) -> str:
+    """OCR a single cropped display region using custom segment analysis."""
+    import cv2
+    import numpy as np
+    
+    img = cv2.imread(str(image_path), cv2.IMREAD_GRAYSCALE)
+    if img is None: return "0"
+    
+    # Bridge digits
+    kernel_bridge = np.ones((7, 7), np.uint8)
+    inverted = cv2.bitwise_not(img)
+    bridged = cv2.morphologyEx(inverted, cv2.MORPH_CLOSE, kernel_bridge)
+    n_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(bridged, connectivity=8)
+    
+    digit_blobs = []
+    crop_h = img.shape[0]
+    for i in range(1, n_labels):
+        x, y, w, h, area = stats[i]
+        if h > crop_h * 0.4 and area > 100:
+            digit_blobs.append((x, y, w, h))
+    
+    digit_blobs = sorted(digit_blobs, key=lambda b: b[0])
+    
+    display_val = ""
+    for dx, dy, dw, dh in digit_blobs:
+        pad = 5
+        y1, y2 = max(0, dy-pad), min(img.shape[0], dy+dh+pad)
+        x1, x2 = max(0, dx-pad), min(img.shape[1], dx+dw+pad)
+        digit_img = img[y1:y2, x1:x2]
+        display_val += decode_7segment(digit_img)
+        
+    return display_val or "0"
 
