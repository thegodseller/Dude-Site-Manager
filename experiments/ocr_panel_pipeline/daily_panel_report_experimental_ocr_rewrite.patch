+            name = source.get("name", "Unknown Panel")
+            url = source.get("url")
+            LOG.info(">>> Processing %s: %s", name, url)
+            
+            # 1. Capture & OCR
+            try:
+                img_path = capture_snapshot(source=args.source, nvr_url=url)
+                ocr_results, _ = run_ocr(img_path)
+                rows = build_rows_from_regions(ocr_results)
+                
+                # Format sub-report
+                combined_messages.append(f"[{name}]")
+                for i, (left, right) in enumerate(rows, 1):
+                    combined_messages.append(f"  {left.ljust(5)} {right}")
+                combined_messages.append("") # Spacer
+                
+            except Exception as e:
+                LOG.error("Failed to process %s: %s", name, e)
+                combined_messages.append(f"[{name}] ⚠️ Error: {e}\n")
+
+        final_message = "\n".join(combined_messages)
+        LOG.info("Final Report Content:\n%s", final_message)
+
+        if args.test_ocr_only:
+            return 0
+
+        # Send to negotiator
+        return send_to_negotiator(final_message, args.negotiator_url).get("status") == "success"
+
     except Exception as exc:
         LOG.exception("Pipeline failed with unhandled error: %s", exc)
